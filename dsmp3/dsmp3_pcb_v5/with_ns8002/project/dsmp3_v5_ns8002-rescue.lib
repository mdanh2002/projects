# AUDIO_CONN-Connector
#
DEF AUDIO_CONN-Connector J 0 40 Y Y 1 F N
F0 "J" -650 -750 50 H V C CNN
F1 "AUDIO_CONN-Connector" -450 -50 50 H V C CNN
F2 "" 0 0 50 H I C CNN
F3 "" 0 0 50 H I C CNN
DRAW
S -650 -100 -100 -700 0 1 0 f
X LEFT_AUD 1 0 -150 100 L 50 50 1 1 I
X LEFT_JACK 2 0 -250 100 L 50 50 1 1 I
X RIGHT_AUD 3 0 -350 100 L 50 50 1 1 I
X RIGHT_JACK 4 0 -450 100 L 50 50 1 1 I
X NC 5 0 -550 100 L 50 50 1 1 N
X GND 6 0 -650 100 L 50 50 1 1 I
ENDDRAW
ENDDEF
